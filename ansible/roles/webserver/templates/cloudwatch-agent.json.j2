{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/httpd/library-portal-access.log",
            "log_group_name": "{{ cloudwatch_log_group }}",
            "log_stream_name": "{instance_id}/apache-access",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/httpd/library-portal-error.log",
            "log_group_name": "{{ cloudwatch_log_group }}",
            "log_stream_name": "{instance_id}/apache-error",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/library-portal/gunicorn.log",
            "log_group_name": "{{ cloudwatch_log_group }}",
            "log_stream_name": "{instance_id}/gunicorn",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
